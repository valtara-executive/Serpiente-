<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#0D0D1A"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7B68EE"
            android:contentDescription="Atrás" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7B68EE"
            android:contentDescription="Adelante" />

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/url_bar_bg"
            android:hint="Buscar o ingresar URL..."
            android:textColorHint="#44445A"
            android:textColor="#E0E0FF"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:selectAllOnFocus="true" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7B68EE"
            android:contentDescription="Recargar" />

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7B68EE"
            android:contentDescription="Inicio" />

        <ImageButton
            android:id="@+id/btnCast"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_cast"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7B68EE"
            android:alpha="0.5"
            android:contentDescription="Enviar a TV" />

        <androidx.mediarouter.app.MediaRouteButton
            android:id="@+id/mediaRouteButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:mediaRouteTypes="user"
            android:tint="#7B68EE" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:progressTint="#7B68EE"
        android:progressBackgroundTint="#1A1A2E"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
